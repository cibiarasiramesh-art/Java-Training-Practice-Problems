#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    int n;
    scanf("%d",&n);
    int a;
    int bal;
    
    int count=0;
    while(n>100){
        scanf("%d",&a);
        n=n-a;
        if(n>100){
             count++;
            bal=n;
            
        }
       
    }
    printf("%d %d",bal,count);
    return 0;
}
